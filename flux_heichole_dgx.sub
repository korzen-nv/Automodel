#!/bin/bash
# =============================================================================
# FLUX.1-dev fine-tuning on HeiChole surgical data — Draco OCI cluster
# =============================================================================

#SBATCH -A healthcareeng_holoscan
#SBATCH -p batch_singlenode
#SBATCH -t 04:00:00
#SBATCH -N 1
#SBATCH --gpus-per-node=8
#SBATCH --ntasks-per-node=1
#SBATCH -J flux-heichole
#SBATCH --output=/lustre/fsw/portfolios/healthcareeng/users/pkorzeniowsk/automodel/slurm_jobs/%x_%j.out
#SBATCH --error=/lustre/fsw/portfolios/healthcareeng/users/pkorzeniowsk/automodel/slurm_jobs/%x_%j.err

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
LUSTRE=/lustre/fsw/portfolios/healthcareeng/users/pkorzeniowsk/automodel
AUTOMODEL_DIR=${LUSTRE}/Automodel
CONFIG=examples/diffusion/finetune/flux_heichole_dgx.yaml

echo "=== Job Info ==="
echo "Host: $(hostname)"
echo "Date: $(date)"
echo "GPUs:"
nvidia-smi -L
echo ""

# ---------------------------------------------------------------------------
# Multi-node environment
# ---------------------------------------------------------------------------
export MASTER_ADDR=$(scontrol show hostnames "$SLURM_JOB_NODELIST" | head -n 1)
export MASTER_PORT=${MASTER_PORT:-13742}

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
export WANDB_API_KEY=${WANDB_API_KEY:-}
export HF_TOKEN=${HF_TOKEN:-}
export HF_HOME=${LUSTRE}/.hf_cache
export WANDB_MODE=disabled

# ---------------------------------------------------------------------------
# Set up Python environment
# ---------------------------------------------------------------------------
export UV_CACHE_DIR=${LUSTRE}/.uv_cache
export PATH=${HOME}/.local/bin:${PATH}

cd ${AUTOMODEL_DIR}

echo "=== Installing Python environment ==="
uv sync --extra diffusion
echo "=== Environment ready ==="

echo "Python: $(uv run python --version)"
echo "Torch: $(uv run python -c 'import torch; print(torch.__version__)')"
echo ""

# ---------------------------------------------------------------------------
# Launch training
# ---------------------------------------------------------------------------
echo "=== Starting training ==="
srun bash -c "\
    export UV_CACHE_DIR=${LUSTRE}/.uv_cache && \
    export PATH=${HOME}/.local/bin:\${PATH} && \
    export HF_HOME=${LUSTRE}/.hf_cache && \
    export HF_TOKEN=${HF_TOKEN} && \
    export WANDB_MODE=disabled && \
    cd ${AUTOMODEL_DIR} && \
    uv run torchrun \
        --nproc_per_node=\${SLURM_GPUS_PER_NODE:-8} \
        --nnodes=\${SLURM_NNODES:-1} \
        --rdzv_backend=c10d \
        --rdzv_endpoint=\${MASTER_ADDR}:\${MASTER_PORT} \
        examples/diffusion/finetune/finetune.py \
        -c ${CONFIG}"
